{"nodes": [{"id": "docs_superpowers_plans_2026_07_08_spotmap_stage5_material_theme_green_m3_theme", "label": "Custom Green Terminal M3 Theme", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage5-material-theme.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replace the stock azure-blue prebuilt theme with a custom M3 theme (green primary, dark scheme, IBM Plex Mono typography, density 0) authored in theme.scss and wired via angular.json, so the terminal look is driven by --mat-* system tokens instead of overrides."}, {"id": "docs_superpowers_plans_2026_07_08_spotmap_stage5_material_theme_no_white_rule", "label": "No-White Rule", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage5-material-theme.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No white or near-white on any controlled surface (including the Material select dropdown panel/overlay and the map iframe) \u2014 surfaces render on dark --color-surface with phosphor text to keep the CRT/matrix identity intact."}, {"id": "docs_superpowers_plans_2026_07_08_spotmap_stage5_material_theme_remove_ngdeep_overrides", "label": "Remove ::ng-deep/!important via M3 Tokens", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage5-material-theme.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "With the M3 theme doing the heavy lifting, delete the ::ng-deep .mat-mdc-* + !important blocks in map.component.css and re-express the terminal touches via --mat-* system-variable overrides plus minimal GLOBAL rules (the select panel is a CDK overlay outside the component DOM); target 0 ::ng-deep and near-zero !important."}, {"id": "docs_superpowers_plans_2026_07_08_spotmap_stage5_material_theme_signal_lost_error_state", "label": "SIGNAL LOST Map Error/Timeout State", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage5-material-theme.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Back the iframe with near-black --color-surface so a blank/slow/failed embed never flashes white, and add a signal-driven error/timeout state (~15s) showing '> SIGNAL LOST // MAP UNREACHABLE' with a retry affordance and the iframe title for a11y."}, {"id": "docs_superpowers_plans_2026_07_08_spotmap_stage5_material_theme_monochrome_nav_glyphs", "label": "Monochrome Terminal Nav Glyphs", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage5-material-theme.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replace the color emoji nav icons (home/map/about) with monochrome terminal glyphs (green-stroke inline SVG or ASCII marks) that inherit currentColor/phosphor glow; glyphs aria-hidden, label text retained."}], "edges": [{"source": "docs_superpowers_plans_2026_07_08_spotmap_stage5_material_theme_green_m3_theme", "target": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage5_material_theme", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage5-material-theme.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_plans_2026_07_08_spotmap_stage5_material_theme_remove_ngdeep_overrides", "target": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage5_material_theme", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage5-material-theme.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_plans_2026_07_08_spotmap_stage5_material_theme_signal_lost_error