{"nodes": [{"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_program", "label": "Vienna Spotmap Audit Refactor Program", "file_type": "document", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Bring the Angular app to production readiness across correctness, design-system, architecture and polish as a staged, gated program on branch refactor/audit-p0-p3, without changing its matrix/terminal look or animation behavior."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_standalone_signals", "label": "Standalone Components + Signals", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All components standalone; use input()/output()/signal()/computed() instead of @Input()/@Output()/EventEmitter unless there is a documented reason \u2014 modern Angular idioms."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_matrix_aesthetic_preservation", "label": "Matrix Aesthetic Preservation", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Preserve the matrix aesthetic (dark bg, monospace, green-on-black, subtle glow) and all animation logic/timing/durations at every step; the refactor must be behavior-preserving."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_green_gate", "label": "Green Gate (build + tests pass per stage)", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each stage ends green (ng build + ng test pass) and is a reviewable, revertible checkpoint; a task is committed only when the gate holds, otherwise it stops/holds at the last green point."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_design_token_ssot", "label": "Design Token SSOT", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Encode matrix identity (color/type/space/anim/breakpoints) as CSS vars + a Tailwind theme so a single source of truth exists before any style migration."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage0_stabilization", "label": "Stage 0 \u2014 Stabilization (P0)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Fix the two memory leaks (resize listener, MutationObserver), guard localStorage against crashes, and repair three broken specs so the suite is fully green \u2014 the baseline all later work builds on."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage1_platform_upgrade", "label": "Stage 1 \u2014 Platform Upgrade (Angular 18\u219222 + Tailwind v4)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Stepwise ng update 18\u219219\u219220\u219221\u219222 plus TS bump then Tailwind v4; hold at the last green major if one cannot be made green, Tailwind falls back to 3.4."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage2_impeccable_pipeline", "label": "Stage 2 \u2014 Impeccable Design Pipeline", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Run /impeccable init through critique, layout, contrast/color, typography, motion and polish to produce PRODUCT.md and a design direction that feeds Stages 3\u20135 and P3."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage3_design_tokens", "label": "Stage 3 \u2014 Design Tokens", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Encode the matrix identity as CSS vars + Tailwind theme \u2014 the single source of truth established before any style migration."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage4_drop_bootstrap", "label": "Stage 4 \u2014 Drop Bootstrap", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Migrate Bootstrap utilities/grid to Tailwind and remove the dependency + angular.json entry, dropping ~302 kB of CSS and unparseable-selector warnings while keeping layout unchanged."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage5_material_theme", "label": "Stage 5 \u2014 Material M3 Terminal Theme", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Custom green M3 theme with --mat-* token overrides at global scope removes all ::ng-deep/!important and root-causes the color-render bug."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage6_architecture", "label": "Stage 6 \u2014 Architecture / API Modernization (P1)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Signals API, reliable ASCII glyph measurement, zone/perf, and router-driven nav \u2014 modernizing to current Angular idioms while preserving behavior and timing."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage7_cleanup", "label": "Stage 7 \u2014 Cleanup / Dead-code / Docs (P2)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Remove dead code, centralize magic numbers, add docs/README, and normalize formatting \u2014 pure cleanup with zero behavior change."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage8_a11y_ux", "label": "Stage 8 \u2014 A11y + UX + Content (P3)", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Accessibility, an opt-in skippable intro, matrix-styled Home/About content and map error states make the CRT experience accessible and less punishing on repeat visits."}, {"id": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage9_finalize", "label": "Stage 9 \u2014 Finalize", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-07-spotmap-audit-refactor.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Retune bundle budgets, lazy-load routes and run a full verify so the branch ends 10/10 green with a clean build."}], "edges": [{"source": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage1_platform_upgrade", "targ