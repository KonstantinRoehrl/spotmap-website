{"nodes": [{"id": "docs_superpowers_plans_2026_07_08_spotmap_stage8_a11y_ux_reduced_motion_fallbacks", "label": "prefers-reduced-motion Fallbacks", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage8-a11y-ux.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every CRT motion (glitch-text scramble, loading-bar matrix, nav-bar glow, keyframes) gets a reduced-motion fallback \u2014 static end-state or crossfade under matchMedia('(prefers-reduced-motion: reduce)') \u2014 without changing behavior for users without the preference, so accessibility is preserved."}, {"id": "docs_superpowers_plans_2026_07_08_spotmap_stage8_a11y_ux_skippable_session_intro", "label": "Once-Per-Session Skippable Intro", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage8-a11y-ux.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Recorded user decision: play the intro once per browser session (sessionStorage introSeen flag, guarded for private mode), skip straight to the map on later loads; skippable any time via click/tap/Esc with an accessible [ SKIP ] affordance; reduced-motion shows the end-state instantly \u2014 less punishing on repeat visits."}, {"id": "docs_superpowers_plans_2026_07_08_spotmap_stage8_a11y_ux_font_re_measure", "label": "Font Ready Re-Measure", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage8-a11y-ux.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deferred from Stage 7: add document.fonts.ready.then(() => updateFontSize()) in ascii-animation-text so the first glyph measurement isn't taken on the fallback font before IBM Plex Mono loads; guarded for environments without document.fonts."}, {"id": "docs_superpowers_plans_2026_07_08_spotmap_stage8_a11y_ux_monochrome_country_codes", "label": "Monochrome Country Codes in City Select", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage8-a11y-ux.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Recorded user decision: replace the full-color flag emoji in the mat-select value and optgroup labels with monochrome 2-letter ISO country codes in phosphor green (group header uppercased country name, trigger 'city \u00b7 AT'); no color emoji on the surface."}, {"id": "docs_superpowers_plans_2026_07_08_spotmap_stage8_a11y_ux_home_about_content", "label": "Home + About Terminal Content", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage8-a11y-ux.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Populate the empty pages in the design voice (raw/DIY, cryptic-insider, sarcastic-but-caring): Home = short manifesto + amber care-channel (RESPECT THE LOCALS / TAKE CARE OF PEDESTRIANS, amber \u226410%) + [ ENTER THE MAP ] route; About = how-to + time-travel ethos + credits + skate-at-your-own-risk disclaimer. Drafted for user review."}, {"id": "docs_superpowers_plans_2026_07_08_spotmap_stage8_a11y_ux_accessibility", "label": "Accessibility (a11y) Audit", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage8-a11y-ux.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ensure the mat-select has an accessible label, trigger/options stay keyboard-navigable, map state changes are announced (role=alert on error, aria-live=polite on loading), and the iframe has a title \u2014 plus aria-hidden decorative <pre>, aria-current and focus states across the app."}], "edges": [{"source": "docs_superpowers_plans_2026_07_08_spotmap_stage8_a11y_ux_reduced_motion_fallbacks", "target": "