{"nodes": [{"id": "docs_superpowers_plans_2026_07_08_spotmap_stage4_drop_bootstrap_bootstrap_to_tailwind_migration", "label": "Bootstrap \u2192 Tailwind Utility Migration", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage4-drop-bootstrap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Like-for-like migration of Bootstrap utility/grid classes in the 4 templates to Tailwind equivalents, then removing the dependency \u2014 dropping ~250\u2013300 kB of CSS and the unparseable-selector build warnings while keeping the rendered layout unchanged at every breakpoint."}, {"id": "docs_superpowers_plans_2026_07_08_spotmap_stage4_drop_bootstrap_value_based_spacing_mapping", "label": "Value-Based Spacing Scale Mapping", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage4-drop-bootstrap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Bootstrap's p/m scale (0,.25,.5,1,1.5,3rem) and Tailwind's (n\u00d70.25rem) differ, so classes must be mapped by rem VALUE not by number (BS *-3=1rem \u2192 Tailwind 4, BS *-4=1.5rem \u2192 6, BS *-5=3rem \u2192 12); grid col-* map to width fractions with no gutter added since the templates have no .row."}], "edges": [{"source": "docs_superpowers_plans_2026_07_08_spotmap_stage4_drop_bootstrap_bootstrap_to_tailwind_migration", "target": "docs_superpowers_plans_2026_07_07_spotmap_audit_refactor_stage4_drop_bootstrap", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-07-08-spotmap-stage4-drop-bootstrap.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_plans_2026_07_08_spotmap_stage4_drop_bootstrap_value_based_spacing_mapping", "target": "docs_superpowers_plans_2026_07_08_spotmap_stage4_drop_bootstrap_bootstrap_to_tailwind_migration", "